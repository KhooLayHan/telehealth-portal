{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "OpenTelemetry": {
      "IncludeScopes": true,
      "IncludeFormattedMessage": true,
      "ParseStateValues": true
    }
  },
  "ConnectionStrings": {
    "Database": "Host=ep-holy-poetry-ammotzlh.c-5.us-east-1.aws.neon.tech;Database=telehealth;Username=neondb_owner;Password=npg_Um32usEGAPtf;SSL Mode=VerifyFull;Channel Binding=Require;"
  },
  "Jwt": {
    "Secret": "dev-secret-key-at-least-32-chars-long!!"
  },
  "Aws": {
  },
  "AWS_S3_PROFILE_IMAGES_BUCKET": "telehealth-profile-images",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }, 
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://telehealth_seq:5341"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://telehealth_seq:5341/ingest/otlp/v1/logs",
          "protocol": "HttpProtobuf",
          "headers": {
            "X-Seq-ApiKey": "DOjvrcXB9RfyEGDwyKX2"
          },
          "resourceAttributes": {
            "service.name": "TeleHealth.Api"
          }
        }
      }
    ],
    "Enrich": [      
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
